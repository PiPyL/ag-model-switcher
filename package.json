{
  "name": "ag-model-switcher",
  "displayName": "AG Model Switcher",
  "description": "Auto-select AI model in Antigravity IDE via shortcuts — supports favorite slots (macOS, Windows, Linux)",
  "version": "7.0.0",
  "publisher": "pipyl",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/PiPyL/ag-model-switcher"
  },
  "bugs": {
    "url": "https://github.com/PiPyL/ag-model-switcher/issues"
  },
  "homepage": "https://github.com/PiPyL/ag-model-switcher#readme",
  "icon": "logo.png",
  "keywords": ["ai", "model", "switcher", "antigravity", "hotkey"],
  "galleryBanner": {
    "color": "#1e1e2e",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": ["Other", "Keymaps"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "agModelSwitcher.openPicker",
        "title": "Open Model Picker",
        "category": "AG Model Switcher",
        "icon": "$(hubot)"
      },
      {
        "command": "agModelSwitcher.cycleNext",
        "title": "Cycle Next Model (Instant)",
        "category": "AG Model Switcher",
        "icon": "$(arrow-right)"
      },
      {
        "command": "agModelSwitcher.cyclePrev",
        "title": "Cycle Previous Model (Instant)",
        "category": "AG Model Switcher",
        "icon": "$(arrow-left)"
      },
      {
        "command": "agModelSwitcher.slot1",
        "title": "Select Model #1",
        "category": "AG Model Switcher"
      },
      {
        "command": "agModelSwitcher.slot2",
        "title": "Select Model #2",
        "category": "AG Model Switcher"
      },
      {
        "command": "agModelSwitcher.slot3",
        "title": "Select Model #3",
        "category": "AG Model Switcher"
      },
      {
        "command": "agModelSwitcher.slot4",
        "title": "Select Model #4",
        "category": "AG Model Switcher"
      },
      {
        "command": "agModelSwitcher.slot5",
        "title": "Select Model #5",
        "category": "AG Model Switcher"
      },
      {
        "command": "agModelSwitcher.slot6",
        "title": "Select Model #6",
        "category": "AG Model Switcher"
      },
      {
        "command": "agModelSwitcher.slot7",
        "title": "Select Model #7",
        "category": "AG Model Switcher"
      },
      {
        "command": "agModelSwitcher.slot8",
        "title": "Select Model #8",
        "category": "AG Model Switcher"
      },
      {
        "command": "agModelSwitcher.diagnose",
        "title": "Diagnose - Test Auto-Select",
        "category": "AG Model Switcher",
        "icon": "$(search)"
      }
    ],
    "keybindings": [
      {
        "command": "agModelSwitcher.openPicker",
        "key": "ctrl+shift+m",
        "mac": "ctrl+shift+m"
      },
      {
        "command": "agModelSwitcher.cycleNext",
        "key": "ctrl+shift+.",
        "mac": "ctrl+shift+."
      },
      {
        "command": "agModelSwitcher.cyclePrev",
        "key": "ctrl+shift+,",
        "mac": "ctrl+shift+,"
      },
      {
        "command": "agModelSwitcher.slot1",
        "key": "ctrl+shift+1",
        "mac": "ctrl+shift+1"
      },
      {
        "command": "agModelSwitcher.slot2",
        "key": "ctrl+shift+2",
        "mac": "ctrl+shift+2"
      },
      {
        "command": "agModelSwitcher.slot3",
        "key": "ctrl+shift+3",
        "mac": "ctrl+shift+3"
      },
      {
        "command": "agModelSwitcher.slot4",
        "key": "ctrl+shift+4",
        "mac": "ctrl+shift+4"
      },
      {
        "command": "agModelSwitcher.slot5",
        "key": "ctrl+shift+5",
        "mac": "ctrl+shift+5"
      },
      {
        "command": "agModelSwitcher.slot6",
        "key": "ctrl+shift+6",
        "mac": "ctrl+shift+6"
      },
      {
        "command": "agModelSwitcher.slot7",
        "key": "ctrl+shift+7",
        "mac": "ctrl+shift+7"
      },
      {
        "command": "agModelSwitcher.slot8",
        "key": "ctrl+shift+8",
        "mac": "ctrl+shift+8"
      },
      {
        "command": "agModelSwitcher.diagnose",
        "key": "ctrl+shift+d ctrl+shift+m",
        "mac": "ctrl+shift+d ctrl+shift+m"
      }
    ],
    "configuration": {
      "title": "AG Model Switcher",
      "properties": {
        "agModelSwitcher.modelOrder": {
          "type": "array",
          "items": { "type": "string" },
          "default": [
            "Claude Sonnet 4.6 (Thinking)",
            "Claude Opus 4.6 (Thinking)",
            "GPT-OSS 120B (Medium)",
            "Gemini 3.5 Flash (Medium)",
            "Gemini 3.5 Flash (High)",
            "Gemini 3.5 Flash (Low)",
            "Gemini 3.1 Pro (Low)",
            "Gemini 3.1 Pro (High)"
          ],
          "markdownDescription": "The order of models in the **native picker** (original UI). **MUST match exactly** the order displayed from top to bottom. The extension uses this order for keyboard navigation."
        },
        "agModelSwitcher.slots": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "markdownDescription": "Favorite models assigned to `Ctrl+Shift+1~8`. Model names must exist in `modelOrder`. If left empty, `modelOrder` will be used directly.\n\nExample: keep only 3 frequently used models:\n```json\n[\"Gemini 3.5 Flash (High)\", \"Claude Sonnet 4.6 (Thinking)\", \"Gemini 3.1 Pro (High)\"]\n```"
        },
        "agModelSwitcher.autoSelect": {
          "type": "boolean",
          "default": true,
          "description": "Automatically select model using keyboard simulation (macOS: AppleScript, Windows: PowerShell, Linux: xdotool/ydotool)"
        },
        "agModelSwitcher.linuxTool": {
          "type": "string",
          "enum": ["xdotool", "ydotool", "xte"],
          "default": "xdotool",
          "markdownDescription": "Linux keyboard simulation tool.\n- **xdotool**: X11 (most common, `sudo apt install xdotool`)\n- **ydotool**: Wayland (`sudo apt install ydotool`, requires uinput)\n- **xte**: xautomation (`sudo apt install xautomation`)"
        },
        "agModelSwitcher.showStatusBar": {
          "type": "boolean",
          "default": true,
          "description": "Show the Model Switcher button on the status bar"
        }
      }
    }
  }
}
